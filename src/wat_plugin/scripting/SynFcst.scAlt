<?xml version="1.0" encoding="UTF-8"?>
<ScriptingAlt Name="GenFcsts">
  <Description>
    <desc cnt="0" value="Generates forecasts via an script using the command line interface -- Prado Example.  EDIT THIS FILE IN WAT!" />
  </Description>
  <ScriptFile>scripts/RunRCmd.py</ScriptFile>
  <TimeStep>15MIN</TimeStep>
  <DataLocations>
    <DataLocation Name="Prado" Class="hec2.model.DataLocation" DssPath="//Prado/Flow//15MIN/alt:ap:Scripting-GenFcsts/" ComputeType="Computed" Model="Scripting-Hydrograph_unscaler" Parameter="Flow" OutOfDate="false" PrevModelIndex="0">
      <ModelAlternative Name="GenFcsts" Program="Scripting" />
      <DownStreamLocation>
        <DataLocation Name="Prado_IN-combined" Class="hec2.model.DataLocation" DssPath="//Prado_IN-combined/Flow//15MIN/C:000050|HFO:FRA_50yr:Scripting-Hydrograph_unscaler/" ComputeType="Computed" Parameter="Flow" OutOfDate="false" PrevModelIndex="0">
          <ModelAlternative Name="Hydrograph_unscaler" Program="Scripting" />
        </DataLocation>
      </DownStreamLocation>
    </DataLocation>
  </DataLocations>
</ScriptingAlt>